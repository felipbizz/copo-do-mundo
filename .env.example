# =============================================================================
# Copo do Mundo - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment
# For local development, you can use .env.local or set these in your shell
# =============================================================================

# -----------------------------------------------------------------------------
# Storage Backend Configuration
# -----------------------------------------------------------------------------
# Options: "local" or "gcp"
# - "local": Use local CSV files and file system (for development)
# - "gcp": Use BigQuery and Cloud Storage (for production)
STORAGE_BACKEND=local

# -----------------------------------------------------------------------------
# Google Cloud Platform Configuration
# -----------------------------------------------------------------------------
# Required when STORAGE_BACKEND=gcp
# These values are also used in GitHub Actions secrets for CI/CD deployment

# GCP Project ID where resources are deployed
GCP_PROJECT_ID=your-project-id

# BigQuery Configuration
# Dataset name for storing votes
BIGQUERY_DATASET=copo_do_mundo

# Table name within the dataset
BIGQUERY_TABLE=votes

# Cloud Storage bucket name for storing images
# Must be globally unique
CLOUD_STORAGE_BUCKET=your-project-id-copo-do-mundo-images

# GCP Authentication (for local development only)
# Path to service account JSON key file
# Not needed in Cloud Run (uses service account attached to the service)
# Example: /path/to/service-account-key.json
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# GCP Region (optional, defaults to us-central1)
# Used for creating resources in the setup script
GCP_REGION=us-central1

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Admin password for accessing the admin panel
# Change this to a secure password in production!
ADMIN_PASSWORD=admin2024

# -----------------------------------------------------------------------------
# Local Storage Configuration
# -----------------------------------------------------------------------------
# Only used when STORAGE_BACKEND=local
# These are the default paths, you can override if needed

# Path to CSV file for storing votes (relative to project root)
DATA_FILE=data/votes.csv

# Directory path for storing images (relative to project root)
IMAGES_DIR=data/images

# =============================================================================
# GitHub Actions Variables (for CI/CD)
# =============================================================================
# The following variables should be configured in GitHub:
# Settings → Secrets and variables → Actions → Variables
#
# Required Variables:
# - GCP_PROJECT_ID: Your GCP project ID
# - BIGQUERY_DATASET: copo_do_mundo
# - BIGQUERY_TABLE: votes
# - CLOUD_STORAGE_BUCKET: e.g. my-project-images
# - WIF_PROVIDER: The Workload Identity Provider ID
# - WIF_SERVICE_ACCOUNT: Service account for WIF
# - CLOUD_RUN_SERVICE_ACCOUNT: Service account for Cloud Run
#
# NOTE: ADMIN_PASSWORD is now securely stored in GCP Secret Manager!
# You do NOT need any GitHub secrets anymore.
# =============================================================================

# =============================================================================
# Example Configurations
# =============================================================================

# Local Development (default):
# STORAGE_BACKEND=local
# ADMIN_PASSWORD=admin2024

# Production (GCP):
# STORAGE_BACKEND=gcp
# GCP_PROJECT_ID=my-production-project
# BIGQUERY_DATASET=copo_do_mundo
# BIGQUERY_TABLE=votes
# CLOUD_STORAGE_BUCKET=my-production-project-copo-do-mundo-images
# ADMIN_PASSWORD=secure-random-password-here
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/prod-service-account.json

# Staging (GCP):
# STORAGE_BACKEND=gcp
# GCP_PROJECT_ID=my-staging-project
# BIGQUERY_DATASET=copo_do_mundo_staging
# BIGQUERY_TABLE=votes
# CLOUD_STORAGE_BUCKET=my-staging-project-copo-do-mundo-images
# ADMIN_PASSWORD=staging-password
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/staging-service-account.json
# =============================================================================
